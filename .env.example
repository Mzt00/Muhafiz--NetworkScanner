# ── Censys (WAN exposure scanning) ────────────────────────
# Get free credentials at: search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=your_censys_api_secret_here

# ── Community Contribution API ────────────────────────────
MUHAFIZ_CONTRIBUTE_ENDPOINT=https://api.muhafiz.dev/v1/contribute
MUHAFIZ_UPDATE_ENDPOINT=https://api.muhafiz.dev/v1/fingerprints.json

# ── Scanner ───────────────────────────────────────────────
SUBNET=192.168.1.0/24
SCAN_INTERVAL_MINUTES=60

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_PORT=8501

# ── Supabase (website database — set up later) ────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# ── GitHub API (for API backend — maintainers only) ───────
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=Mzt00/Muhafiz--NetworkScanner
